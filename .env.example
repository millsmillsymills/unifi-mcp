# UniFi MCP Server Configuration
# Copy to .env and fill in your values

# Mode: "readonly" (default) or "readwrite"
# In readonly mode, write tools are completely hidden from MCP clients
UNIFI_MODE=readonly

# ─── Network API ───────────────────────────────────────────────────────────────
# Local UniFi Network controller
UNIFI_NETWORK_HOST=192.168.1.1
UNIFI_NETWORK_PORT=443
UNIFI_NETWORK_API=              # Your Network API key
UNIFI_NETWORK_SITE=default
UNIFI_NETWORK_VERIFY_SSL=false  # Set to true if using valid SSL cert
# Optional SHA-256 pin of the leaf cert (colons optional, case-insensitive).
# When set, the client refuses to talk to any other cert and ignores the
# system CA bundle entirely. Capture with:
#   openssl s_client -connect <host>:443 -servername <host> </dev/null 2>/dev/null \
#     | openssl x509 -fingerprint -sha256 -noout
# UNIFI_NETWORK_CERT_FINGERPRINT=

# ─── Protect API ──────────────────────────────────────────────────────────────
# On split deployments (Protect on a separate UCK/NVR, not the gateway),
# UNIFI_PROTECT_HOST MUST be set explicitly — see #107. The default silently
# inherits UNIFI_NETWORK_HOST and validate_connection will fail at startup,
# disabling every Protect tool with a single WARN line.
# UNIFI_PROTECT_HOST=192.168.1.1
# UNIFI_PROTECT_PORT=443
UNIFI_PROTECT_API=              # Your Protect API key (Protect-scoped, not Network)
# UNIFI_PROTECT_VERIFY_SSL=false
# Optional SHA-256 pin for the Protect leaf cert; same format as Network.
# UNIFI_PROTECT_CERT_FINGERPRINT=

# ─── Site Manager API ─────────────────────────────────────────────────────────
# Cloud API — connects to api.ui.com
UNIFI_SITE_MANAGER_API=         # Your Site Manager API key

# ─── General ──────────────────────────────────────────────────────────────────
UNIFI_REQUEST_TIMEOUT=30        # Request timeout in seconds
UNIFI_MAX_RETRIES=3             # Max retry attempts on connection errors

# ─── Diagnostics ──────────────────────────────────────────────────────────────
# When false (default), HTTP error bodies are redacted before being logged at
# DEBUG: known sensitive keys (passphrases, secrets, tokens) are replaced with
# "***REDACTED***" and the user-facing exception message also drops them. Flip
# to true only to capture untouched bodies for diagnosis on a trusted log sink.
# UNIFI_LOG_RAW_BODIES=false
